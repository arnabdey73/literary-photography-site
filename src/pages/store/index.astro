---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const printable = (await getCollection('photography'))
  .filter((p) => p.data.available_for_print)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Prints — Arnab Dey" description="Fine-art prints of selected photographs, made to order on archival paper.">
  <section class="page-head">
    <div class="container-narrow text-center">
      <span class="eyebrow">The Print Store</span>
      <h1>Take it home</h1>
      <hr class="divider" />
      <p>Selected photographs, printed to order on archival paper. Checkout is being built — for now, browse what will be available and subscribe to hear when it opens.</p>
      <div class="mt-8"><a href="/subscribe" class="btn btn-primary">Notify Me at Launch</a></div>
    </div>
  </section>

  {printable.length > 0 && (
    <section class="section" style="padding-top: 0;">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">Coming to the store</span>
          <h2>Prints in preparation</h2>
        </div>
        <div class="photo-grid">
          {printable.map((photo) => (
            <a href={`/photography/${photo.slug}`} class="photo-item">
              <img src={photo.data.image} alt={photo.data.altText} loading="lazy" />
              <div class="photo-overlay">
                <h3>{photo.data.title}</h3>
                <p>{photo.data.location ?? 'Fine-art print'}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section section-alt">
    <div class="container">
      <div class="section-head"><span class="eyebrow">What to expect</span><h2>Made with care</h2></div>
      <div class="grid grid-3">
        <div class="expect reveal">
          <h3>Archival quality</h3>
          <p>Giclée prints on museum-grade paper, colour-managed for depth and longevity.</p>
        </div>
        <div class="expect reveal">
          <h3>Made to order</h3>
          <p>Printed individually in a range of sizes, so each piece is produced just for you.</p>
        </div>
        <div class="expect reveal">
          <h3>Shipped with care</h3>
          <p>Packed flat or rolled to protect the surface, with worldwide delivery.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head { padding: clamp(8rem, 16vh, 12rem) 0 clamp(3rem, 6vw, 5rem); }
  .expect { padding: 2rem; border: 1px solid var(--line); }
  .expect h3 { margin-bottom: 0.75rem; }
</style>
