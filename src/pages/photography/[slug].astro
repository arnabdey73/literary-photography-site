---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const photos = await getCollection('photography');
  return photos.map((photo) => ({
    params: { slug: photo.slug },
    props: { photo },
  }));
}

const { photo } = Astro.props;
const { Content } = await photo.render();

const linkedPoem = photo.data.poemRef ? await getEntry(photo.data.poemRef) : null;

const allPhotos = await getCollection('photography');
let related = allPhotos
  .filter((p) => p.slug !== photo.slug)
  .filter((p) => p.data.tags.some((tag: string) => photo.data.tags.includes(tag)))
  .slice(0, 3);
if (related.length === 0) {
  related = allPhotos
    .filter((p) => p.slug !== photo.slug)
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 3);
}

const dateStr = photo.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${photo.data.title} — Photography`} description={photo.data.description} image={photo.data.image}>
  <article class="plate">
    <!-- Full-bleed image -->
    <figure class="plate-stage">
      <img src={photo.data.image} alt={photo.data.altText} fetchpriority="high" />
    </figure>

    <!-- Verse + title -->
    <header class="plate-head container-narrow text-center">
      <span class="eyebrow">{photo.data.location ?? 'Photograph'}</span>
      <h1>{photo.data.title}</h1>
      {photo.data.verse && (
        <p class="plate-verse verse reveal">{photo.data.verse}</p>
      )}
      <hr class="divider" />
      <ul class="plate-meta">
        <li><span>Made</span>{dateStr}</li>
        {photo.data.location && <li><span>Where</span>{photo.data.location}</li>}
        {photo.data.camera && <li><span>Camera</span>{photo.data.camera}</li>}
      </ul>
    </header>

    <!-- Story -->
    {photo.body && photo.body.trim().length > 0 && (
      <div class="prose plate-story"><Content /></div>
    )}

    <!-- Linked full poem -->
    {linkedPoem && (
      <div class="container-narrow">
        <a href={`/poetry/${linkedPoem.slug}`} class="poem-link reveal">
          <span class="eyebrow">The full poem</span>
          <h3>{linkedPoem.data.title} &rarr;</h3>
        </a>
      </div>
    )}

    <!-- Print CTA -->
    {photo.data.available_for_print && (
      <section class="container-narrow">
        <div class="print-cta reveal">
          <span class="eyebrow">Take it home</span>
          <h3>Available as a fine-art print</h3>
          <p>Printed on archival paper, made to order in a range of sizes.</p>
          <a href="/store" class="btn btn-primary">Order a Print</a>
        </div>
      </section>
    )}

    <!-- Footer nav -->
    <div class="container-narrow plate-nav">
      <a href="/photography" class="btn btn-ghost">&larr; Back to Gallery</a>
      <button type="button" id="shareBtn" class="btn btn-ghost">Share</button>
    </div>

    <!-- Related -->
    {related.length > 0 && (
      <section class="section section-alt">
        <div class="container">
          <div class="section-head"><span class="eyebrow">More plates</span></div>
          <div class="photo-grid">
            {related.map((p) => (
              <a href={`/photography/${p.slug}`} class="photo-item">
                <img src={p.data.image} alt={p.data.altText} loading="lazy" />
                <div class="photo-overlay">
                  <h3>{p.data.title}</h3>
                  {p.data.location && <p>{p.data.location}</p>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<script>
  document.getElementById('shareBtn')?.addEventListener('click', async () => {
    const data = { title: document.title, url: window.location.href };
    if (navigator.share) { try { await navigator.share(data); } catch {} }
    else { await navigator.clipboard.writeText(window.location.href); alert('Link copied to clipboard'); }
  });
</script>

<style>
  .plate-stage {
    width: 100%;
    max-height: 86vh;
    overflow: hidden;
    background: var(--bg-alt);
    display: flex;
    justify-content: center;
  }
  .plate-stage img { width: 100%; max-height: 86vh; object-fit: contain; }

  .plate-head { padding: clamp(3rem, 6vw, 5rem) var(--gutter) 1rem; }
  .plate-head h1 { margin-bottom: 1.5rem; }
  .plate-head .plate-verse { margin-bottom: 0.5rem; }

  .plate-meta {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2.5rem;
    padding: 0;
  }
  .plate-meta li {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--text-dim);
  }
  .plate-meta span {
    display: block;
    font-size: 0.64rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 0.35rem;
  }

  .plate-story { padding-top: clamp(2.5rem, 5vw, 4rem); }

  .poem-link {
    display: block;
    text-align: center;
    padding: 2.5rem;
    margin-top: 3rem;
    border: 1px solid var(--line);
    color: inherit;
    transition: border-color var(--transition);
  }
  .poem-link:hover { border-color: var(--gold-dim); }
  .poem-link h3 { color: var(--gold); }

  .print-cta {
    text-align: center;
    padding: clamp(2.5rem, 5vw, 4rem);
    margin-top: 3rem;
    border: 1px solid var(--line);
  }
  .print-cta p { margin-bottom: 1.75rem; }

  .plate-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 3rem;
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }
</style>
