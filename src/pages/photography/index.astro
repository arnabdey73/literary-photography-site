---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const photos = (await getCollection('photography'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="Photography — Arnab Dey"
  description="A gallery of photographs, each paired with a line of verse. Landscape and visual poetry by Arnab Dey."
>
  <section class="page-head">
    <div class="container-narrow text-center">
      <span class="eyebrow">The Gallery</span>
      <h1>Photographs</h1>
      <hr class="divider" />
      <p>Click any frame to view it large, with its verse. Each image is a plate — light held still, a few words to keep it company.</p>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      {photos.length > 0 ? (
        <div class="photo-grid">
          {photos.map((photo, i) => (
            <button
              type="button"
              class="photo-item lb-trigger"
              data-index={i}
              data-src={photo.data.image}
              data-alt={photo.data.altText}
              data-title={photo.data.title}
              data-verse={photo.data.verse ?? ''}
              data-location={photo.data.location ?? ''}
              data-slug={photo.slug}
              data-print={photo.data.available_for_print ? '1' : ''}
            >
              <img src={photo.data.image} alt={photo.data.altText} loading="lazy" />
              <div class="photo-overlay">
                {photo.data.verse
                  ? <p class="verse">{photo.data.verse}</p>
                  : <h3>{photo.data.title}</h3>}
                {photo.data.location && <p>{photo.data.location}</p>}
              </div>
            </button>
          ))}
        </div>
      ) : (
        <p class="text-center">The gallery is being hung. Please return soon.</p>
      )}
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photograph viewer">
    <button class="lightbox-btn lightbox-close" id="lbClose" aria-label="Close">&times;</button>
    <button class="lightbox-btn lightbox-prev" id="lbPrev" aria-label="Previous">&#8249;</button>
    <button class="lightbox-btn lightbox-next" id="lbNext" aria-label="Next">&#8250;</button>
    <figure class="lightbox-figure">
      <img id="lbImg" src="" alt="" />
      <figcaption class="lightbox-caption">
        <p class="verse" id="lbVerse"></p>
        <p class="meta" id="lbMeta"></p>
        <a class="btn" id="lbLink" href="#" style="margin-top:1rem;">View Plate</a>
      </figcaption>
    </figure>
  </div>
</BaseLayout>

<script>
  const triggers = Array.from(document.querySelectorAll<HTMLElement>('.lb-trigger'));
  const lb = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lbImg') as HTMLImageElement;
  const lbVerse = document.getElementById('lbVerse')!;
  const lbMeta = document.getElementById('lbMeta')!;
  const lbLink = document.getElementById('lbLink') as HTMLAnchorElement;
  let current = 0;

  function show(index: number) {
    const n = triggers.length;
    current = (index + n) % n;
    const el = triggers[current];
    lbImg.src = el.dataset.src || '';
    lbImg.alt = el.dataset.alt || '';
    lbVerse.textContent = el.dataset.verse || '';
    lbVerse.style.display = el.dataset.verse ? '' : 'none';
    const bits = [el.dataset.title, el.dataset.location].filter(Boolean);
    lbMeta.textContent = bits.join(' · ');
    lbLink.href = `/photography/${el.dataset.slug}`;
  }

  function open(index: number) {
    show(index);
    lb.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    lb.classList.remove('active');
    document.body.style.overflow = '';
  }

  triggers.forEach((el, i) => el.addEventListener('click', () => open(i)));
  document.getElementById('lbClose')!.addEventListener('click', close);
  document.getElementById('lbPrev')!.addEventListener('click', () => show(current - 1));
  document.getElementById('lbNext')!.addEventListener('click', () => show(current + 1));
  lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('active')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>

<style>
  .page-head { padding: clamp(8rem, 16vh, 12rem) 0 clamp(3rem, 6vw, 5rem); }
  .lb-trigger { border: none; padding: 0; cursor: pointer; font: inherit; text-align: left; }
</style>
