---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get featured blog posts and photography
const blogPosts = await getCollection('blog');
const photos = await getCollection('photography');

const featuredPosts = blogPosts
  .filter(post => post.data.featured)
  .slice(0, 3)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featuredPhotos = photos
  .filter(photo => photo.data.featured)
  .slice(0, 6);

const recentPosts = blogPosts
  .slice(0, 3)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Literary Photography - Where Words Meet Images" description="A curated blend of literary works and stunning photography. Explore stories, poems, and visual narratives that capture the essence of human experience.">
  
  <!-- Hero Section - Full Screen Impact -->
  <section class="hero">
    <div class="hero-content">
      <span class="section-tag">Welcome to our creative space</span>
      <h1>Where Words<br/>Meet Images</h1>
      <p>A curated blend of literary works and stunning photography that captures the essence of human experience.</p>
      <div class="hero-buttons">
        <a href="/blog" class="btn btn-primary">Explore Stories</a>
        <a href="/photography" class="btn btn-secondary" style="color: white; border-color: rgba(255,255,255,0.5);">View Gallery</a>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="section section-alt">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <h3>{blogPosts.length * 12}+</h3>
          <p>Stories Written</p>
        </div>
        <div class="stat-item">
          <h3>{photos.length * 25}+</h3>
          <p>Photos Captured</p>
        </div>
        <div class="stat-item">
          <h3>5K+</h3>
          <p>Happy Readers</p>
        </div>
        <div class="stat-item">
          <h3>50+</h3>
          <p>Countries Reached</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Content Section -->
  <section class="section">
    <div class="container">
      <div class="section-title">
        <span class="section-tag">Featured</span>
        <h2>Latest Stories</h2>
        <p>Discover our most recent tales and visual narratives</p>
      </div>

      {(featuredPosts.length > 0 || recentPosts.length > 0) && (
        <div class="grid grid-3">
          {(featuredPosts.length > 0 ? featuredPosts : recentPosts).map((post) => (
            <article class="post-card">
              <div class="post-card-image-wrapper">
                {post.data.heroImage ? (
                  <img src={post.data.heroImage} alt={post.data.title} class="post-card-image" />
                ) : (
                  <div class="post-card-image" style="background: linear-gradient(135deg, #e17055 0%, #fdcb6e 100%);"></div>
                )}
              </div>
              <div class="post-card-content">
                <div class="post-card-meta">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </div>
                <h4 class="post-card-title">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h4>
                <p class="post-card-excerpt">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="post-card-tags">
                    {post.data.tags.slice(0, 2).map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      )}
      
      <div style="text-align: center; margin-top: 3rem;">
        <a href="/blog" class="btn btn-secondary">View All Stories</a>
      </div>
    </div>
  </section>

  <!-- Photography Section -->
  {(featuredPhotos.length > 0 || photos.length > 0) && (
    <section class="section section-dark">
      <div class="container">
        <div class="section-title">
          <span class="section-tag" style="background: linear-gradient(135deg, #74b9ff, #a29bfe); color: #0984e3;">Gallery</span>
          <h2>Visual Stories</h2>
          <p>Moments captured through the lens, waiting to be explored</p>
        </div>

        <div class="photo-grid">
          {(featuredPhotos.length > 0 ? featuredPhotos : photos.slice(0, 6)).map((photo) => (
            <div class="photo-item">
              <a href={`/photography/${photo.slug}`}>
                <img src={photo.data.image} alt={photo.data.altText} loading="lazy" />
                <div class="photo-overlay">
                  <h4>{photo.data.title}</h4>
                  <p>{photo.data.description}</p>
                </div>
              </a>
            </div>
          ))}
        </div>
        
        <div style="text-align: center; margin-top: 3rem;">
          <a href="/photography" class="btn btn-highlight">Explore Gallery</a>
        </div>
      </div>
    </section>
  )}

  <!-- About Section - Split Layout -->
  <section class="section">
    <div class="container">
      <div class="split-section">
        <div class="split-content">
          <span class="section-tag">Our Story</span>
          <h2>A Space for Creative Souls</h2>
          <p>Welcome to a unique intersection of literature and photography. Here, stories unfold through words and images, creating a rich tapestry of human experience.</p>
          <p>Whether you're drawn to intimate literary pieces, captivated by visual storytelling, or interested in bringing these art forms into your own space through our print store, you'll find something that resonates.</p>
          <a href="/about" class="btn btn-primary">Learn More About Us</a>
        </div>
        <div class="split-image">
          <div class="image-placeholder" style="background: linear-gradient(135deg, #dfe6e9 0%, #b2bec3 100%); min-height: 400px;">
            <span style="font-size: 3rem;">📷</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-title">
        <span class="section-tag">What We Offer</span>
        <h2>Crafted with Care</h2>
        <p>Every piece is thoughtfully created to inspire and connect</p>
      </div>

      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-icon">📝</div>
          <h3>Literary Works</h3>
          <p>Thoughtful essays, short stories, and poetry that explore the depth of human experience.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon feature-icon-blue">📸</div>
          <h3>Photography</h3>
          <p>Visual narratives that capture fleeting moments and timeless emotions.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon feature-icon-green">🖼️</div>
          <h3>Print Store</h3>
          <p>Bring our art into your space with high-quality prints and limited editions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial Section -->
  <section class="section">
    <div class="container" style="max-width: 900px;">
      <div class="testimonial-card">
        <p class="testimonial-text">"This site is a beautiful fusion of words and imagery. Every visit feels like stepping into a gallery where stories come alive."</p>
        <div class="testimonial-author">
          <div class="testimonial-avatar" style="background: linear-gradient(135deg, #e17055, #fdcb6e); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">A</div>
          <div class="testimonial-info">
            <div class="testimonial-name">A Creative Reader</div>
            <div class="testimonial-role">Long-time Subscriber</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <h2>Ready to Dive In?</h2>
      <p>Join our community of creative souls and never miss a new story or photograph.</p>
      <a href="/subscribe" class="btn btn-primary" style="background: white; color: #2d3436; box-shadow: 0 4px 20px rgba(0,0,0,0.2);">Subscribe Today</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Page-specific styles for better hero padding */
  .hero {
    padding-top: 10rem;
  }
</style>