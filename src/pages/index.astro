---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const photos = (await getCollection('photography'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const poems = (await getCollection('poetry'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const heroPhoto = photos.find((p) => p.data.featured) ?? photos[0];

// Featured "plates" — photographs that carry a verse
const plates = photos.filter((p) => p.data.featured && p.data.verse).slice(0, 3);
const gridPhotos = (plates.length ? photos.filter((p) => !plates.includes(p)) : photos).slice(0, 6);

const featuredPoems = (poems.filter((p) => p.data.featured).length ? poems.filter((p) => p.data.featured) : poems).slice(0, 3);
---

<BaseLayout
  title="Arnab Dey — Photographs & Verse"
  description="A dark gallery where photographs are paired with verse. Landscape and visual poetry by Arnab Dey, with fine-art prints available."
  image={heroPhoto?.data.image}
>
  <!-- Hero -->
  <section class="hero">
    {heroPhoto && (
      <img class="hero-img" src={heroPhoto.data.image} alt={heroPhoto.data.altText} fetchpriority="high" />
    )}
    <div class="hero-scrim"></div>
    <div class="hero-content">
      <span class="eyebrow">Photographs &amp; Verse</span>
      <h1>Where light<br/>meets language</h1>
      {heroPhoto?.data.verse && <p class="hero-verse verse">{heroPhoto.data.verse}</p>}
      <div class="hero-actions">
        <a href="/photography" class="btn btn-primary">Enter the Gallery</a>
        <a href="/poetry" class="btn">Read the Verse</a>
      </div>
    </div>
    <a href="#featured" class="hero-scroll" aria-label="Scroll to content">&#8595;</a>
  </section>

  <!-- Featured plates: photo + verse -->
  {plates.length > 0 && (
    <section id="featured" class="section">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">Selected Plates</span>
          <h2>Image &amp; verse, paired</h2>
          <hr class="divider" />
          <p>A photograph and a few lines of poetry, the way they were meant to be seen — together.</p>
        </div>
        <div class="plates">
          {plates.map((photo, i) => (
            <a href={`/photography/${photo.slug}`} class={`plate reveal ${i % 2 ? 'plate-reverse' : ''}`}>
              <div class="plate-img"><img src={photo.data.image} alt={photo.data.altText} loading="lazy" /></div>
              <div class="plate-body">
                <p class="plate-verse verse">{photo.data.verse}</p>
                <span class="plate-meta">{photo.data.title}{photo.data.location ? ` · ${photo.data.location}` : ''}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Gallery preview -->
  {gridPhotos.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow">Gallery</span>
          <h2>Recent work</h2>
        </div>
        <div class="photo-grid reveal">
          {gridPhotos.map((photo) => (
            <a href={`/photography/${photo.slug}`} class="photo-item">
              <img src={photo.data.image} alt={photo.data.altText} loading="lazy" />
              <div class="photo-overlay">
                <h3>{photo.data.title}</h3>
                {photo.data.location && <p>{photo.data.location}</p>}
              </div>
            </a>
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="/photography" class="btn">View Full Gallery</a>
        </div>
      </div>
    </section>
  )}

  <!-- Poetry teaser -->
  {featuredPoems.length > 0 && (
    <section class="section">
      <div class="container-narrow">
        <div class="section-head reveal">
          <span class="eyebrow">From the Verse</span>
          <h2>Words for the quiet hours</h2>
        </div>
        <div class="poem-list">
          {featuredPoems.map((poem) => (
            <a href={`/poetry/${poem.slug}`} class="poem-row reveal">
              <h3>{poem.data.title}</h3>
              {poem.data.form && <span class="poem-form">{poem.data.form}</span>}
              {poem.data.description && <p>{poem.data.description}</p>}
            </a>
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="/poetry" class="btn">Read All Poems</a>
        </div>
      </div>
    </section>
  )}

  <!-- Closing CTA -->
  <section class="section section-alt">
    <div class="container-narrow text-center reveal">
      <span class="eyebrow">Stay Close</span>
      <h2>New plates, now and then</h2>
      <hr class="divider" />
      <p>An occasional letter when a new photograph or poem finds its way out. No noise.</p>
      <div class="mt-8"><a href="/subscribe" class="btn btn-primary">Subscribe</a></div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(to right, rgba(10,10,12,0.85) 0%, rgba(10,10,12,0.45) 45%, rgba(10,10,12,0.25) 100%),
      linear-gradient(to top, rgba(10,10,12,0.7) 0%, transparent 40%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: var(--maxw);
    width: 100%;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  .hero h1 {
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 500;
    margin-bottom: 1.5rem;
  }
  .hero-verse {
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    color: rgba(236, 232, 225, 0.9);
    max-width: 30ch;
    margin-bottom: 2.5rem;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero-scroll {
    position: absolute;
    bottom: 2rem; left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: var(--text-dim);
    font-size: 1.5rem;
    animation: bob 2.4s ease-in-out infinite;
  }
  @keyframes bob { 0%,100% { transform: translate(-50%, 0); } 50% { transform: translate(-50%, 8px); } }

  /* Plates */
  .plates { display: flex; flex-direction: column; gap: clamp(3rem, 6vw, 6rem); }
  .plate {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    color: inherit;
  }
  .plate-reverse { direction: rtl; }
  .plate-reverse > * { direction: ltr; }
  .plate-img { overflow: hidden; aspect-ratio: 4 / 5; background: var(--bg-alt); }
  .plate-img img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--transition-slow); opacity: 0.94; }
  .plate:hover .plate-img img { transform: scale(1.04); opacity: 1; }
  .plate-body { text-align: center; }
  .plate-body .plate-verse { text-align: left; margin: 0 0 1.5rem; }
  .plate-reverse .plate-body .plate-verse { text-align: left; }
  .plate-meta {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  /* Poetry teaser */
  .poem-list { border-top: 1px solid var(--line); }
  .poem-row {
    display: block;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--line);
    color: inherit;
    transition: padding-left var(--transition);
  }
  .poem-row:hover { padding-left: 0.75rem; }
  .poem-row h3 { display: inline; color: var(--text); transition: color var(--transition-fast); }
  .poem-row:hover h3 { color: var(--gold); }
  .poem-form {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-left: 0.75rem;
  }
  .poem-row p { margin: 0.6rem 0 0; color: var(--text-dim); font-size: 0.95rem; }

  @media (max-width: 768px) {
    .plate, .plate-reverse { grid-template-columns: 1fr; direction: ltr; }
    .plate-body .plate-verse { text-align: center; }
  }
</style>
