---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Subscribe — Arnab Dey" description="An occasional letter when a new photograph or poem finds its way out. No noise.">
  <section class="page-head">
    <div class="container-narrow text-center">
      <span class="eyebrow">Stay Close</span>
      <h1>Subscribe</h1>
      <hr class="divider" />
      <p>An occasional letter when a new plate is hung or a new poem is set in type. No noise, no spam — unsubscribe in one click.</p>
    </div>
  </section>

  <div class="content-wrapper" style="padding-top: 0;">
    <form class="sub-form" id="subForm">
      <label class="field">
        <span>Email</span>
        <input type="email" name="email" required placeholder="you@example.com" />
      </label>
      <label class="field">
        <span>Name <em>(optional)</em></span>
        <input type="text" name="name" placeholder="Your name" />
      </label>

      <fieldset class="field">
        <legend>Most interested in</legend>
        <label class="check"><input type="checkbox" name="interests" value="photography" /> Photography</label>
        <label class="check"><input type="checkbox" name="interests" value="poetry" /> Poetry</label>
        <label class="check"><input type="checkbox" name="interests" value="prints" /> Prints</label>
      </fieldset>

      <button type="submit" class="btn btn-primary" style="width: 100%;">Subscribe</button>
      <p class="note">No spam, ever. I'll only write when there's something worth your while.</p>
    </form>
  </div>
</BaseLayout>

<script>
  document.getElementById('subForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    // TODO: wire to a newsletter provider (Buttondown / ConvertKit / Mailchimp).
    alert('Thank you — newsletter sign-up is being wired up. Please check back soon.');
  });
</script>

<style>
  .page-head { padding: clamp(8rem, 16vh, 12rem) 0 clamp(2.5rem, 5vw, 4rem); }
  .sub-form { display: flex; flex-direction: column; gap: 1.75rem; }
  .field { display: flex; flex-direction: column; gap: 0.6rem; border: 0; padding: 0; margin: 0; }
  .field > span, .field legend {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .field em { text-transform: none; letter-spacing: 0; }
  input[type="email"], input[type="text"] {
    background: var(--bg-alt);
    border: 1px solid var(--line);
    color: var(--text);
    padding: 0.9rem 1rem;
    font-size: 1rem;
    font-family: var(--font-sans);
    transition: border-color var(--transition);
  }
  input[type="email"]:focus, input[type="text"]:focus { outline: none; border-color: var(--gold); }
  .check {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-dim);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    text-transform: none;
    letter-spacing: 0;
  }
  .check input { accent-color: var(--gold); }
  .note { text-align: center; color: var(--text-faint); font-size: 0.85rem; margin: 0; }
</style>
