---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">Arnab Dey</a>
        <p class="footer-tagline">Photographs paired with verse — a quiet record of light and language.</p>
        <div class="social">
          <a href="#" aria-label="Instagram" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="#" aria-label="Email" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-10 6L2 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <h4>Explore</h4>
          <ul>
            <li><a href="/photography">Photography</a></li>
            <li><a href="/poetry">Poetry</a></li>
            <li><a href="/blog">Journal</a></li>
            <li><a href="/store">Prints</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>More</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/subscribe">Subscribe</a></li>
            <li><a href="mailto:arnabdey009@gmail.com">Contact</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Arnab Dey</p>
      <p>Where light meets language.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-alt);
    border-top: 1px solid var(--line);
    margin-top: auto;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 3rem;
    padding: clamp(3.5rem, 7vw, 6rem) 0 3rem;
  }
  .footer-logo {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--text);
    display: inline-block;
    margin-bottom: 1rem;
  }
  .footer-logo:hover { color: var(--gold); }
  .footer-tagline {
    color: var(--text-dim);
    font-size: 0.95rem;
    max-width: 34ch;
    margin-bottom: 1.5rem;
  }
  .social { display: flex; gap: 0.75rem; }
  .social-link {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--line);
    color: var(--text-dim);
    transition: all var(--transition);
  }
  .social-link:hover { color: var(--gold); border-color: var(--gold-dim); }

  .footer-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .footer-col h4 {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 1.25rem;
  }
  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 0.7rem; }
  .footer-col a { color: var(--text-dim); font-size: 0.92rem; }
  .footer-col a:hover { color: var(--gold); }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.75rem 0;
    border-top: 1px solid var(--line);
  }
  .footer-bottom p { margin: 0; color: var(--text-faint); font-size: 0.82rem; letter-spacing: 0.04em; }

  @media (max-width: 768px) {
    .footer-top { grid-template-columns: 1fr; gap: 2.5rem; }
    .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>
